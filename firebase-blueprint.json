{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the application",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["client", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "A product in the catalog",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "sku": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "cost": { "type": "number" },
        "stock": { "type": "number" },
        "imageUrl": { "type": "string" },
        "offerPrice": { "type": "number" },
        "isNew": { "type": "boolean" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category", "price", "stock", "status"]
    },
    "Order": {
      "title": "Order",
      "description": "A wholesale order placed by a client",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array", "items": { "$ref": "#/entities/OrderItem" } },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status", "createdAt"]
    },
    "Promotion": {
      "title": "Promotion",
      "description": "Configured promotions (volume, percentage) applied to products or categories",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["volume", "percentage"] },
        "targetType": { "type": "string", "enum": ["all", "category", "product"] },
        "targetId": { "type": "string" },
        "value": { "type": "number" },
        "buyQuantity": { "type": "number" },
        "payQuantity": { "type": "number" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "type", "targetType"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "User" },
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": { "$ref": "Product" },
      "description": "Catalog products"
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "Order" },
      "description": "Client orders"
    },
    "/promotions/{promoId}": {
      "schema": { "$ref": "Promotion" },
      "description": "System promotions"
    }
  }
}
