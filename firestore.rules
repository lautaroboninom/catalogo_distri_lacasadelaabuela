rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: users
    // Document ID: user UID
    // Fields:
    //   - email: string (required)
    //   - role: string (required) enum: ['client', 'admin']
    //
    // Collection: products
    // Document ID: auto-generated string
    // Fields:
    //   - name: string (required)
    //   - category: string (required)
    //   - price: number (required)
    //   - cost: number (required for admin edits)
    //   - stock: number (required)
    //   - imageUrl: string
    //   - status: string enum ['active', 'inactive']
    //
    // Collection: orders
    // Document ID: auto-generated string
    // Fields:
    //   - userId: string (required)
    //   - total: number (required)
    //   - status: string (required)
    //   - items: list
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuthenticated() && (
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        (request.auth.token.email == "lautaroboninom@gmail.com" && request.auth.token.email_verified == true)
      );
    }
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    match /test/connection {
        allow read: if true;
    }

    match /users/{userId} {
        allow read: if isOwner(userId) || isAdmin();
        
        // Only allow creating their own user doc (e.g. at signup) with role 'client'
        allow create: if isAuthenticated() && isOwner(userId)
                    && request.resource.data.role == 'client'
                    && request.resource.data.email == request.auth.token.email;
                    
        // Only admin can update users (e.g. to change role)
        allow update: if isAuthenticated() && isAdmin();
        
        allow delete: if false;
    }

    match /products/{productId} {
        // Publicly readable
        allow read: if true;
        
        // Only admin can write
        allow write: if isAdmin();
    }

    match /promotions/{promoId} {
        // Publicly readable so app can evaluate discounts
        allow read: if true;
        
        // Only admin can write
        allow write: if isAdmin();
    }

    match /orders/{orderId} {
        // Client can read their own orders. Admin can read all.
        allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
        
        // Client can create orders
        allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
        
        // Only Admin can update order status
        allow update: if isAuthenticated() && isAdmin();
        
        // Orders generally shouldn't be deleted, maybe just cancelled via update
        allow delete: if false;
    }
  }
}
